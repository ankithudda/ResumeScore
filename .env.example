# ==========================================
# ResumeScore Environment Configuration
# ==========================================

# 1.NVIDIA AI Endpoint (or OpenAI, depending on your client setup)
# Get your API key from: https://build.nvidia.com/
NVIDIA_API_KEY="your_api_key_here"

# (Optional) Add any other configuration variables your app uses below
# ENVIRONMENT="development"
# MAX_RETRIES=3

# 2. SECURITY & NETWORK CONFIGURATION (FastAPI Backend)
# Must be a valid JSON array string. Add your production domain when deploying.
# Default values match local Streamlit execution ports.
ALLOWED_ORIGINS='["http://localhost:8501", "http://127.0.0.1:8501"]'

# 3. GLOBAL OBSERVABILITY SETTINGS
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL="INFO"